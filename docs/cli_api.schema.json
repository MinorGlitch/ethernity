{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MinorGlitch/ethernity/blob/master/docs/cli_api.schema.json",
  "title": "Ethernity CLI API Event",
  "description": "JSON Schema for one NDJSON event emitted by `ethernity api`.",
  "oneOf": [
    {
      "$ref": "#/$defs/startedEvent"
    },
    {
      "$ref": "#/$defs/phaseEvent"
    },
    {
      "$ref": "#/$defs/progressEvent"
    },
    {
      "$ref": "#/$defs/warningEvent"
    },
    {
      "$ref": "#/$defs/artifactEvent"
    },
    {
      "$ref": "#/$defs/resultEvent"
    },
    {
      "$ref": "#/$defs/errorEvent"
    }
  ],
  "$defs": {
    "pathString": {
      "type": "string",
      "minLength": 1
    },
    "command": {
      "type": "string",
      "enum": [
        "backup",
        "recover",
        "kit",
        "settings_get",
        "settings_set"
      ]
    },
    "metadataObject": {
      "type": "object",
      "additionalProperties": true
    },
    "startedEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "schema_version",
        "command",
        "args"
      ],
      "properties": {
        "type": {
          "const": "started"
        },
        "schema_version": {
          "const": 1
        },
        "command": {
          "$ref": "#/$defs/command"
        },
        "args": {
          "$ref": "#/$defs/metadataObject"
        }
      }
    },
    "phaseEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "id",
        "label"
      ],
      "properties": {
        "type": {
          "const": "phase"
        },
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "progressEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "phase",
        "current",
        "total",
        "unit",
        "label",
        "details"
      ],
      "properties": {
        "type": {
          "const": "progress"
        },
        "phase": {
          "type": "string",
          "minLength": 1
        },
        "current": {
          "type": "integer",
          "minimum": 0
        },
        "total": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "unit": {
          "type": [
            "string",
            "null"
          ]
        },
        "label": {
          "type": [
            "string",
            "null"
          ]
        },
        "details": {
          "$ref": "#/$defs/metadataObject"
        }
      }
    },
    "warningEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "code",
        "message",
        "details"
      ],
      "properties": {
        "type": {
          "const": "warning"
        },
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "details": {
          "$ref": "#/$defs/metadataObject"
        }
      }
    },
    "artifactEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "kind",
        "path",
        "details"
      ],
      "properties": {
        "type": {
          "const": "artifact"
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "$ref": "#/$defs/pathString"
        },
        "details": {
          "$ref": "#/$defs/metadataObject"
        }
      }
    },
    "errorEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "ok",
        "code",
        "message",
        "details"
      ],
      "properties": {
        "type": {
          "const": "error"
        },
        "ok": {
          "const": false
        },
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "details": {
          "$ref": "#/$defs/metadataObject"
        }
      }
    },
    "backupArtifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "qr_document",
        "recovery_document",
        "recovery_kit_index",
        "shard_documents",
        "signing_key_shard_documents"
      ],
      "properties": {
        "qr_document": {
          "$ref": "#/$defs/pathString"
        },
        "recovery_document": {
          "$ref": "#/$defs/pathString"
        },
        "recovery_kit_index": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "shard_documents": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/pathString"
          }
        },
        "signing_key_shard_documents": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/pathString"
          }
        }
      }
    },
    "backupPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sealed",
        "shard_threshold",
        "shard_count",
        "signing_key_mode",
        "signing_key_shard_threshold",
        "signing_key_shard_count"
      ],
      "properties": {
        "sealed": {
          "type": "boolean"
        },
        "shard_threshold": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "shard_count": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "signing_key_mode": {
          "type": "string",
          "enum": [
            "embedded",
            "sharded"
          ]
        },
        "signing_key_shard_threshold": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "signing_key_shard_count": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        }
      }
    },
    "backupResultEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "ok",
        "command",
        "doc_id",
        "output_dir",
        "input_origin",
        "input_roots",
        "input_count",
        "generated_passphrase",
        "artifacts",
        "plan"
      ],
      "properties": {
        "type": {
          "const": "result"
        },
        "ok": {
          "const": true
        },
        "command": {
          "const": "backup"
        },
        "doc_id": {
          "type": "string",
          "pattern": "^[0-9a-f]+$"
        },
        "output_dir": {
          "$ref": "#/$defs/pathString"
        },
        "input_origin": {
          "type": "string",
          "enum": [
            "file",
            "directory",
            "mixed"
          ]
        },
        "input_roots": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "input_count": {
          "type": "integer",
          "minimum": 1
        },
        "generated_passphrase": {
          "type": [
            "string",
            "null"
          ]
        },
        "artifacts": {
          "$ref": "#/$defs/backupArtifacts"
        },
        "plan": {
          "$ref": "#/$defs/backupPlan"
        }
      }
    },
    "recoverManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format_version",
        "input_origin",
        "input_roots",
        "sealed",
        "payload_codec",
        "payload_raw_len",
        "file_count"
      ],
      "properties": {
        "format_version": {
          "type": "integer",
          "minimum": 1
        },
        "input_origin": {
          "type": "string",
          "enum": [
            "file",
            "directory",
            "mixed"
          ]
        },
        "input_roots": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "sealed": {
          "type": "boolean"
        },
        "payload_codec": {
          "type": "string",
          "minLength": 1
        },
        "payload_raw_len": {
          "type": "integer",
          "minimum": 0
        },
        "file_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "recoverFile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifest_path",
        "output_path",
        "size",
        "sha256",
        "mtime"
      ],
      "properties": {
        "manifest_path": {
          "type": "string",
          "minLength": 1
        },
        "output_path": {
          "$ref": "#/$defs/pathString"
        },
        "size": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "mtime": {
          "type": [
            "integer",
            "null"
          ]
        }
      }
    },
    "recoverResultEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "ok",
        "command",
        "output_path",
        "doc_id",
        "auth_status",
        "input_label",
        "input_detail",
        "manifest",
        "files"
      ],
      "properties": {
        "type": {
          "const": "result"
        },
        "ok": {
          "const": true
        },
        "command": {
          "const": "recover"
        },
        "output_path": {
          "$ref": "#/$defs/pathString"
        },
        "doc_id": {
          "type": "string",
          "pattern": "^[0-9a-f]+$"
        },
        "auth_status": {
          "type": "string",
          "minLength": 1
        },
        "input_label": {
          "type": "string",
          "minLength": 1
        },
        "input_detail": {
          "type": "string",
          "minLength": 1
        },
        "manifest": {
          "$ref": "#/$defs/recoverManifest"
        },
        "files": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/recoverFile"
          }
        }
      }
    },
    "kitResultEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "ok",
        "command",
        "output_path",
        "variant",
        "chunk_count",
        "chunk_size",
        "bytes_total",
        "doc_id"
      ],
      "properties": {
        "type": {
          "const": "result"
        },
        "ok": {
          "const": true
        },
        "command": {
          "const": "kit"
        },
        "output_path": {
          "$ref": "#/$defs/pathString"
        },
        "variant": {
          "type": "string",
          "enum": [
            "lean",
            "scanner"
          ]
        },
        "chunk_count": {
          "type": "integer",
          "minimum": 1
        },
        "chunk_size": {
          "type": "integer",
          "minimum": 1
        },
        "bytes_total": {
          "type": "integer",
          "minimum": 1
        },
        "doc_id": {
          "type": "string",
          "pattern": "^[0-9a-f]+$"
        }
      }
    },
    "guiSettings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "template_design",
        "page_size",
        "backup_output_dir",
        "qr_chunk_size",
        "backup_shard_threshold",
        "backup_shard_count",
        "signing_key_mode",
        "signing_key_shard_threshold",
        "signing_key_shard_count",
        "recover_output_dir"
      ],
      "properties": {
        "template_design": {
          "type": "string",
          "minLength": 1
        },
        "page_size": {
          "type": "string",
          "enum": [
            "A4",
            "LETTER"
          ]
        },
        "backup_output_dir": {
          "type": [
            "string",
            "null"
          ]
        },
        "qr_chunk_size": {
          "type": "integer",
          "minimum": 1
        },
        "backup_shard_threshold": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "backup_shard_count": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "signing_key_mode": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "embedded",
            "sharded",
            null
          ]
        },
        "signing_key_shard_threshold": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "signing_key_shard_count": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "recover_output_dir": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "settingsGetResultEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "ok",
        "command",
        "config_path",
        "version",
        "designs",
        "settings"
      ],
      "properties": {
        "type": {
          "const": "result"
        },
        "ok": {
          "const": true
        },
        "command": {
          "const": "settings_get"
        },
        "config_path": {
          "$ref": "#/$defs/pathString"
        },
        "version": {
          "type": "string"
        },
        "designs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "settings": {
          "$ref": "#/$defs/guiSettings"
        }
      }
    },
    "settingsSetResultEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "ok",
        "command",
        "config_path",
        "version",
        "designs",
        "settings"
      ],
      "properties": {
        "type": {
          "const": "result"
        },
        "ok": {
          "const": true
        },
        "command": {
          "const": "settings_set"
        },
        "config_path": {
          "$ref": "#/$defs/pathString"
        },
        "version": {
          "type": "string"
        },
        "designs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "settings": {
          "$ref": "#/$defs/guiSettings"
        }
      }
    },
    "resultEvent": {
      "oneOf": [
        {
          "$ref": "#/$defs/backupResultEvent"
        },
        {
          "$ref": "#/$defs/recoverResultEvent"
        },
        {
          "$ref": "#/$defs/kitResultEvent"
        },
        {
          "$ref": "#/$defs/settingsGetResultEvent"
        },
        {
          "$ref": "#/$defs/settingsSetResultEvent"
        }
      ]
    }
  }
}
