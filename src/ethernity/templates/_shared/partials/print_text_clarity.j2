@media print {
  :root {
    --muted: #374151;
    --muted-soft: #4b5563;
    --ink-soft: #374151;
    --ink-label: #1f2937;
    --ink-muted: #374151;
  }

  html,
  body {
    color: #000 !important;
    text-rendering: geometricPrecision;
    -webkit-font-smoothing: auto;
  }

  code,
  pre,
  kbd,
  samp,
  .font-mono,
  .fallback,
  .fallback-lines,
  .fallback-line,
  .keys-line,
  .fallback-payload,
  .sentinel-fallback-text {
    font-variant-ligatures: none;
  }

  .fallback,
  .fallback-lines,
  .fallback-line,
  .fallback-payload,
  .sentinel-fallback-text {
    color: #000 !important;
  }

  [class*="text-gray-"],
  [class*="text-slate-"],
  [class*="text-zinc-"],
  [class*="text-neutral-"],
  .text-text-secondary-light {
    color: #1f2937 !important;
  }

  .text-white,
  [class*="text-white"] {
    color: #fff !important;
  }

  .subtitle,
  .meta-k,
  .meta-label,
  .mode-row,
  .fallback-title,
  .fallback-label,
  .keys-label,
  .instructions-label,
  .instructions-full-label,
  .section-code,
  .stamp-title,
  .qr-sequence text,
  th,
  label {
    font-weight: 600 !important;
    color: #111827 !important;
  }

  .qr-grid::after {
    opacity: 0.12 !important;
  }

  .qr-sequence line {
    opacity: 0.28 !important;
  }
}
